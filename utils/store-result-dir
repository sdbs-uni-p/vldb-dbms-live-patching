#!/usr/bin/env zsh

set -eu
SCRIPT_PATH=$(readlink -f "$0")
SCRIPT_DIR=${SCRIPT_PATH:h}

if [[ -z "$1" ]]; then
    echo "No name specified"
    exit 1
fi

name=$1
OUTPUT=${SCRIPT_DIR}/../data/${name}
if [ -d ${OUTPUT} ]; then
    echo "${OUTPUT} already exists!"
    exit 1
fi

mkdir -p ${OUTPUT}
echo ${OUTPUT}
